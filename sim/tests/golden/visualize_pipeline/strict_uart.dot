digraph pipeline {
  rankdir=LR;
  ranksep=0.6;
  nodesep=0.4;
  label="Pipeline Flow: /Users/fundou/my_dv_proj/sv_query/sim/tests/fixtures/strict_uart/filelist.f";
  labelloc=t;
  fontsize=14;
  splines=polyline;

  // 2 pipeline regs, 2 control regs
  // 3 state regs, 2 stages

  // === Control signals header row (top, color-coded by target stage) ===
  subgraph cluster_control_header {
    label="Control Signals (7 total, showing 7)";
    style="rounded,filled";
    fillcolor="#fff5e6";
    color="#cc8844";
    fontsize=10;
    rank=min;
    "synchronizer.async_i" [label="async_i\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
    "synchronizer.sync0_o" [label="sync0_o\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
    "synchronizer.sync1" [label="sync1\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
    "uart_top.rx_ready_o" [label="rx_ready_o\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
    "sync_fifo.wr_ptr_q" [label="wr_ptr_q\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
    "0" [label="0\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
    "1" [label="1\n→S0" shape=box style="rounded,filled" fillcolor="#cc6633" fontcolor="white" penwidth=1.5 fontsize=9];
  }

  // === TL;DR ===
  TLDR [shape=plaintext, label="2 pipeline regs · 3 state regs · 2 stages · control shown: 7/7",
        fontsize=12, fontcolor="#664400",
        fillcolor="#fffbe6", style="rounded,filled",
        margin=0.1];
  subgraph cluster_stage0 {
    label="Stage 0";
    style=dashed;
    color="#226699";
    fontsize=11;
    "sync_fifo.pop_data_o" [label="pop_data_o\nREG\\n8bit" shape=box style="rounded,filled" fillcolor="#4488cc" fontcolor="white" penwidth=2.5];
  }

  subgraph cluster_stage1 {
    label="Stage 1";
    style=dashed;
    color="#226699";
    fontsize=11;
    "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" [label="mem[Expression(ExpressionKind.NamedValue)]\nREG\\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" fontcolor="white" penwidth=2.5];
    "sync_fifo.pop_data_o" [label="pop_data_o\
8bit" shape=box style="rounded,filled" fillcolor="#88bbdd" fontcolor="white" penwidth=1];
  }

  // === Data edges (stage → stage) ===
  "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" -> "sync_fifo.pop_data_o" [color="#226699" penwidth=1.5 label="mem[Expression(Expre" fontsize=8];

  // === Control edges (dashed, color-matched to target stage) ===

  // === Legend ===
  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled";
    fillcolor="#f8f8f8";
    color="#aaaaaa";
    fontsize=10;
    rank=sink;
    "legend_pipeline_0" [label="Pipeline Reg" shape=box,style="filled,rounded" fillcolor="#4488cc" fontcolor="white" fontsize=9];
    "legend_pipeline_1" [label="Combinational" shape=box,style="filled,rounded" fillcolor="#88bbdd" fontcolor="white" fontsize=9];
    "legend_pipeline_2" [label="State Reg" shape=box,style="filled,rounded" fillcolor="#cc8844" fontcolor="white" fontsize=9];
    "legend_pipeline_3" [label="Control→S0" shape=box,style="filled,rounded" fillcolor="#cc6633" fontcolor="white" fontsize=9];
    "legend_pipeline_4" [label="Control→S1" shape=box,style="filled,rounded" fillcolor="#aa5599" fontcolor="white" fontsize=9];
    "legend_pipeline_5" [label="Control→S2" shape=box,style="filled,rounded" fillcolor="#5599aa" fontcolor="white" fontsize=9];
    "legend_pipeline_6" [label="Control→S3" shape=box,style="filled,rounded" fillcolor="#aa8855" fontcolor="white" fontsize=9];
  }
}