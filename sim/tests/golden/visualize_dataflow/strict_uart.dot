digraph dataflow {
  rankdir=TB;
  label="Data Flow: /Users/fundou/my_dv_proj/sv_query/sim/tests/fixtures/strict_uart/filelist.f";
  labelloc=t;
  fontsize=14;
  ranksep=0.5;
  nodesep=0.3;
  splines=polyline;

  // === TL;DR ===
  TLDR [shape=plaintext, label="19 data · 7 control · 4 clock nodes",
        fontsize=12, fontcolor="#664400",
        fillcolor="#fffbe6", style="rounded,filled",
        margin=0.1];

  // === Nodes ===
  "0" [label="0\n1bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=1];
  "1" [label="1\n1bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=1];
  "sync_fifo.SIZE" [label="SIZE\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.b01" [label="b01\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.b10" [label="b10\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.count_q" [label="count_q\nREG\n1bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=2];
  "sync_fifo.empty_o" [label="empty_o\nPORT_OUT\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.full_o" [label="full_o\nPORT_OUT\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.mem" [label="mem\n1bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" [label="mem[Expression(ExpressionKind.NamedValue)]\nREG\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=2];
  "sync_fifo.pop_data_o" [label="pop_data_o\nREG\n8bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=2];
  "sync_fifo.pop_i" [label="pop_i\nPORT_IN\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.push_data_i" [label="push_data_i\nPORT_IN\n8bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.push_i" [label="push_i\nPORT_IN\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "sync_fifo.rd_ptr_q" [label="rd_ptr_q\nREG\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=2];
  "sync_fifo.wr_ptr_q" [label="wr_ptr_q\nREG\n1bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=2];
  "synchronizer.async_i" [label="async_i\nPORT_IN\n1bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=1];
  "synchronizer.sync0_o" [label="sync0_o\nREG\n1bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=2];
  "synchronizer.sync1" [label="sync1\nREG\n1bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=2];
  "uart_top.rx_data_o" [label="rx_data_o\nPORT_OUT\n8bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "uart_top.rx_fifo" [label="rx_fifo\nINSTANTIATED_MODULE\n2bit" shape=box style="rounded,filled" fillcolor="#aaaaaa" color="#888888" fontcolor="black" penwidth=1];
  "uart_top.rx_fifo.empty_o" [label="empty_o\nPORT_OUT\n2bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "uart_top.rx_fifo.pop_data_o" [label="pop_data_o\nPORT_OUT\n8bit" shape=box style="rounded,filled" fillcolor="#4488cc" color="#226699" fontcolor="white" penwidth=1];
  "uart_top.rx_ready_o" [label="rx_ready_o\nPORT_OUT\n2bit" shape=box style="rounded,filled" fillcolor="#cc8844" color="#996622" fontcolor="white" penwidth=1];

  // === Data Edges ===
  "synchronizer.async_i" -> "synchronizer.sync1" [color="#226699", style=solid, penwidth=1.5, label="async_i", fontsize=9, xlabel="rst_ni", fontsize=7];
  "synchronizer.sync1" -> "synchronizer.sync0_o" [color="#226699", style=solid, penwidth=1.5, label="sync1", fontsize=9, xlabel="rst_ni", fontsize=7];
  "sync_fifo.push_i" -> "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" [color="#226699", style=solid, penwidth=1.5, label="push_i", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.push_i" -> "sync_fifo.wr_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="push_i", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.pop_i" -> "sync_fifo.pop_data_o" [color="#226699", style=solid, penwidth=1.5, label="pop_i", fontsize=9, xlabel="rst_ni && pop_i && !empty", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.pop_i" -> "sync_fifo.rd_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="pop_i", fontsize=9, xlabel="rst_ni && pop_i && !empty", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.push_data_i" -> "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" [color="#226699", style=solid, penwidth=1.5, label="push_data_i", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.full_o" -> "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" [color="#226699", style=solid, penwidth=1.5, label="full_o", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.full_o" -> "sync_fifo.wr_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="full_o", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.empty_o" -> "sync_fifo.pop_data_o" [color="#226699", style=solid, penwidth=1.5, label="empty_o", fontsize=9, xlabel="rst_ni && pop_i && !empty", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.empty_o" -> "sync_fifo.rd_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="empty_o", fontsize=9, xlabel="rst_ni && pop_i && !empty", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.count_q" -> "sync_fifo.empty_o" [color="#226699", style=solid, penwidth=1.5, label="count_q", fontsize=9];
  "sync_fifo.count_q" -> "sync_fifo.full_o" [color="#226699", style=solid, penwidth=1.5, label="count_q", fontsize=9, penwidth=2.5, color="#224488"];
  "sync_fifo.count_q" -> "sync_fifo.count_q" [color="#226699", style=solid, penwidth=1.5, label="count_q", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.wr_ptr_q" -> "sync_fifo.wr_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="wr_ptr_q", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.SIZE" -> "sync_fifo.full_o" [color="#226699", style=solid, penwidth=1.5, label="count_q", fontsize=9, penwidth=2.5, color="#224488"];
  "sync_fifo.rd_ptr_q" -> "sync_fifo.rd_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="rd_ptr_q", fontsize=9, xlabel="rst_ni && pop_i && !empty", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" -> "sync_fifo.pop_data_o" [color="#226699", style=solid, penwidth=1.5, label="mem[Expression(ExpressionKind....", fontsize=9, xlabel="rst_ni && pop_i && !empty", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.mem[Expression(ExpressionKind.NamedValue)]" -> "sync_fifo.mem" [color="#226699", style=solid, penwidth=1.5, label="_node_0000", fontsize=9];
  "sync_fifo.b10" -> "sync_fifo.count_q" [color="#226699", style=solid, penwidth=1.5, label="b10", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "sync_fifo.b01" -> "sync_fifo.count_q" [color="#226699", style=solid, penwidth=1.5, label="b01", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];
  "uart_top.rx_fifo.pop_data_o" -> "uart_top.rx_fifo.pop_data_o" [color="#226699", style=solid, penwidth=1.5, label="_node_0000", fontsize=9];
  "uart_top.rx_fifo.pop_data_o" -> "uart_top.rx_data_o" [color="#226699", style=solid, penwidth=1.5, label="_node_0000", fontsize=9];
  "uart_top.rx_fifo.pop_data_o" -> "uart_top.rx_fifo" [color="#226699", style=solid, penwidth=1.5, label="pop_data_o", fontsize=9, penwidth=2.5, color="#224488"];
  "uart_top.rx_fifo.empty_o" -> "uart_top.rx_fifo.empty_o" [color="#226699", style=solid, penwidth=1.5, label="_node_0000", fontsize=9];
  "uart_top.rx_fifo.empty_o" -> "uart_top.rx_ready_o" [color="#226699", style=solid, penwidth=1.5, label="_node_0000", fontsize=9];
  "uart_top.rx_fifo.empty_o" -> "uart_top.rx_fifo" [color="#226699", style=solid, penwidth=1.5, label="empty_o", fontsize=9, penwidth=2.5, color="#224488"];
  "1" -> "sync_fifo.wr_ptr_q" [color="#226699", style=solid, penwidth=1.5, label="1", fontsize=9, xlabel="rst_ni && push_i && !full", fontsize=7, penwidth=2.5, color="#224488"];

  // === Key Control Edges ===
  "0" -> "sync_fifo.empty_o" [color="#CC6600", style=dashed, penwidth=1.2];
  "1" -> "sync_fifo.rd_ptr_q" [color="#CC6600", style=dashed, penwidth=1.2, xlabel="rst_ni && pop_i && !empty", fontsize=7];
  "1" -> "sync_fifo.count_q" [color="#CC6600", style=dashed, penwidth=1.2, xlabel="rst_ni && push_i && !full", fontsize=7];

  // === Legend ===
  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled";
    fillcolor="#f8f8f8";
    color="#aaaaaa";
    fontsize=10;
    rank=sink;
    "legend_dataflow_0" [label="Data Reg" shape=box,style="filled,rounded" fillcolor="#4488cc" fontcolor="white" fontsize=9];
    "legend_dataflow_1" [label="Combinational" shape=box,style="filled,rounded" fillcolor="#88bbdd" fontcolor="white" fontsize=9];
    "legend_dataflow_2" [label="Control" shape=box,style=dashed,style="filled,rounded" fillcolor="#cc6633" fontcolor="white" fontsize=9];
    "legend_dataflow_3" [label="Clock" shape=octagon,style="filled,rounded" fillcolor="#996633" fontcolor="white" fontsize=9];
    "legend_dataflow_4" [label="DANGLING" shape=diamond,style="filled,rounded" fillcolor="#cc0000" fontcolor="white" fontsize=9];
    "legend_dataflow_5" [label="X_DRIVER" shape=diamond,style="filled,rounded" fillcolor="#cc8800" fontcolor="white" fontsize=9];
    "legend_dataflow_6" [label="ORPHAN" shape=diamond,style="filled,rounded" fillcolor="#888888" fontcolor="white" fontsize=9];
  }
}