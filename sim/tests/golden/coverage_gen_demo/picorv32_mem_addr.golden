covergroup cg_mem_addr @(posedge clk iff !resetn);
  option.per_instance = 1;
  option.comment = "mem_addr (DATA, 32-bit, risk=30.3)";
  // ---- Primary coverpoint ----
  cp_mem_addr: coverpoint mem_addr {
    // DATA bins: 32-bit range partition
    bins zero  = {32'h0};
    bins byte  = {[32'h1:32'hFF]};          // 1-byte values
    bins word  = {[32'h100:32'hFFFF]};       // 2-byte values
    bins dword = {[32'h10000:32'hFFFFFF]};   // 3-byte values
    bins max   = {32'hFFFF_FFFF};
  }
  // ---- Sample event: @(posedge clk iff !resetn) ----
  //   Data reg — no valid/enable gating found; sample every cycle (may be too eager)
endgroup: cg_mem_addr